# /etc/alloy/secrets.env  (root-owned, chmod 600 — NEVER commit the real file)
# Copy to /etc/alloy/secrets.env on the Pi and fill from the Grafana Cloud portal:
#   Stack: https://mellowmushroom1792.grafana.net  (org 1804779, region us)
#   Prometheus URL + username:  Cloud Portal -> stack -> Prometheus -> "Send Metrics" / Details
#   Loki URL + username:        Cloud Portal -> stack -> Loki -> "Send Logs" / Details
#   Token:  a Cloud Access Policy token with metrics:write + logs:write (policy "pi-turret")
#
# The username is the numeric instance/tenant ID (e.g. 1234567), NOT the stack slug.

GRAFANA_CLOUD_PROM_URL=https://prometheus-prod-XX-prod-us-east-0.grafana.net/api/prom/push
GRAFANA_CLOUD_PROM_USER=000000
GRAFANA_CLOUD_LOKI_URL=https://logs-prod-XXX.grafana.net/loki/api/v1/push
GRAFANA_CLOUD_LOKI_USER=000000
GRAFANA_CLOUD_TOKEN=glc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
